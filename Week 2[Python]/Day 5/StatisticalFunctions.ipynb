    "print(\"Sum:\", np.sum(data))\n",
    "print(\"Mean:\", np.mean(data))\n",
    "print(\"Median:\", np.median(data))\n",
    "print(\"Maximum:\", np.max(data))\n",
    "print(\"Minimum:\", np.min(data))\n",
    "print(\"Standard Deviation:\", np.std(data))"
   ]
