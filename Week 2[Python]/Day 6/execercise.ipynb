   "source": [
    "import numpy as np\n",
    "# Create random matrices\n",
    "X = np.random.randint(1,10,(2,2))\n",
    "Y = np.random.randint(1,10,(2,2))\n",
    "\n",
    "print(\"Matrix X:\")\n",
    "print(X)\n",
    "\n",
    "print(\"Matrix Y:\")\n",
    "print(Y)\n",
    "\n",
    "print(\"Addition:\")\n",
    "print(X+Y)\n",
    "\n",
    "print(\"Multiplication:\")\n",
    "print(np.dot(X,Y))"
   ]
  }
